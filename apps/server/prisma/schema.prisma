generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MatchStatus {
  QUEUED
  ACTIVE
  FINISHED
  ABANDONED
}

model User {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  email        String?  @unique
  username     String   @unique
  passwordHash String?

  matches      MatchPlayer[]
}

model Match {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  status    MatchStatus @default(ACTIVE)
  mode      String      @default("casual") // casual|ranked|ai|tournament...
  region    String?

  rulesJson Json
  stateJson Json

  players   MatchPlayer[]
  moves     Move[]
}

model MatchPlayer {
  id        String   @id @default(cuid())
  matchId   String
  userId    String
  slot      Int
  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, slot])
  @@unique([matchId, userId])
}

model Move {
  id        String   @id @default(cuid())
  matchId   String
  playerId  String
  moveNo    Int
  actionJson Json
  tick      Int
  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, moveNo])
}

